{
  "name": "libs-pin-assign-panel",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/pin-assign-panel/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": [
    "type:ui",
    "domain:pin-assign-panel"
  ],
  "targets": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-pin-assign-panel\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "vitest run --config libs/pin-assign-panel/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
