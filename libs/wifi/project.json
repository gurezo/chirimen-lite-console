{
  "name": "libs-wifi",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/wifi/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": [
    "type:feature",
    "domain:wifi"
  ],
  "implicitDependencies": [
    "libs-dialogs",
    "libs-shared",
    "libs-web-serial"
  ],
  "targets": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-wifi\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "vitest run --config libs/wifi/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
