{
  "name": "libs-remote-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/remote/feature/src",
  "projectType": "library",
  "tags": ["type:feature", "domain:remote"],
  "implicitDependencies": [
    "libs-remote-ui",
    "libs-remote-data-access",
    "libs-remote-util",
    "libs-dialogs",
    "libs-dialogs",
    "libs-shared",
    "libs-shared",
    "libs-terminal-util",
    "libs-web-serial",
    "libs-web-serial"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-remote-feature\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/remote/feature/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}

