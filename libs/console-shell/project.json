{
  "name": "libs-console-shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/console-shell/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "type:feature",
    "domain:console-shell"
  ],
  "implicitDependencies": [
    "libs-chirimen-setup",
    "libs-connect",
    "libs-file-manager",
    "libs-pin-assign-panel",
    "libs-remote",
    "libs-shared",
    "libs-terminal",
    "libs-web-serial"
  ],
  "targets": {
    "build": {
      "dependsOn": [],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-console-shell\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "vitest run --config libs/console-shell/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
