{
  "name": "libs-shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/shared",
  "sourceRoot": "libs/shared/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:shared", "domain:shared"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-shared\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/shared/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/shared/**/*.ts"]
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/shared/.storybook",
        "browserTarget": "libs-shared:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/libs-shared",
        "configDir": "libs/shared/.storybook",
        "browserTarget": "libs-shared:build-storybook",
        "compodoc": false,
        "styles": ["apps/console/src/styles.scss"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/shared/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "libs-shared:build-storybook",
        "staticFilePath": "dist/storybook/libs-shared",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "libs-shared:build-storybook:ci"
        }
      }
    }
  }
}
