{
  "name": "libs-editor",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/editor/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": [
    "type:feature",
    "domain:editor"
  ],
  "implicitDependencies": [
    "libs-console-shell"
  ],
  "targets": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "command": "echo \"build libs-editor\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "command": "vitest run --config libs/editor/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
