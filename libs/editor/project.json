{
  "name": "libs-editor",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/editor",
  "sourceRoot": "libs/editor/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:feature", "domain:editor"],
  "implicitDependencies": [
    "libs-wifi-data-access",
    "libs-console-shell-util"
  ],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-editor\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/editor/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/editor/**/*.ts",
          "libs/editor/**/*.html"
        ]
      }
    }
  }
}
