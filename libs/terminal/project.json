{
  "name": "libs-terminal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/terminal",
  "sourceRoot": "libs/terminal/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:feature", "domain:terminal"],
  "implicitDependencies": ["libs-dialogs", "libs-web-serial"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-terminal\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/terminal/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/terminal/**/*.ts",
          "libs/terminal/**/*.html"
        ]
      }
    }
  }
}
