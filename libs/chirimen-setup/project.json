{
  "name": "libs-chirimen-setup",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/chirimen-setup",
  "sourceRoot": "libs/chirimen-setup/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:feature", "domain:chirimen-setup"],
  "implicitDependencies": ["libs-web-serial", "libs-dialogs", "libs-shared"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-chirimen-setup\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/chirimen-setup/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/chirimen-setup/**/*.ts",
          "libs/chirimen-setup/**/*.html"
        ]
      }
    }
  }
}
