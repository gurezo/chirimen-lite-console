{
  "name": "libs-unsupported-browser",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/unsupported-browser/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-unsupported-browser\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/unsupported-browser/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
