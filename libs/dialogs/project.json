{
  "name": "libs-dialogs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "libs/dialogs",
  "sourceRoot": "libs/dialogs/src",
  "prefix": "choh",
  "projectType": "library",
  "tags": ["type:feature", "domain:dialogs"],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "echo \"build libs-dialogs\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run --config libs/dialogs/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/dialogs/**/*.ts"]
      }
    }
  }
}
